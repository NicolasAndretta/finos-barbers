# ─── SUPABASE ────────────────────────────────────────────────────────────────
# Encontrás estos valores en: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── RESEND (emails transaccionales) ─────────────────────────────────────────
# Creá tu API key en: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key

# ─── MERCADOPAGO ─────────────────────────────────────────────────────────────
# Usá el Access Token de TEST para desarrollo, el de producción para deploy
# Encontralo en: https://www.mercadopago.com.ar/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN=TEST-your_mercadopago_access_token

# ─── APP URL ─────────────────────────────────────────────────────────────────
# En producción, cambiá por tu dominio real (sin trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── SUPABASE ────────────────────────────────────────────────────────────────
# Encontrás estos valores en: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── RESEND (emails transaccionales) ─────────────────────────────────────────
# Creá tu API key en: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key

# ─── MERCADOPAGO (token simple — respaldo) ───────────────────────────────────
# Respaldo si el comercio NO conectó por OAuth. Usá TEST para desarrollo.
# Encontralo en: https://www.mercadopago.com.ar/developers/panel/app
MERCADOPAGO_ACCESS_TOKEN=TEST-your_mercadopago_access_token

# ─── MERCADOPAGO CONNECT (OAuth — recomendado) ───────────────────────────────
# App de Mercado Pago de la PLATAFORMA (Andretta Studio), no la del comercio.
# Panel de developers → Tus integraciones → Crear aplicación → Credenciales/OAuth.
# Configurá la Redirect URI: <NEXT_PUBLIC_SITE_URL>/api/mp/oauth/callback
MP_CLIENT_ID=your_mp_application_id
MP_CLIENT_SECRET=your_mp_client_secret

# ─── APP URL ─────────────────────────────────────────────────────────────────
# URL pública del sitio (sin trailing slash). Usada para el redirect de OAuth.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=https://firebrick-giraffe-301726.hostingersite.com
